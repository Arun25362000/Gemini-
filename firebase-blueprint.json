{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information including role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "joinDate": { "type": "string", "format": "date" }
      },
      "required": ["email", "role", "joinDate"]
    },
    "Contribution": {
      "title": "Monthly Contribution",
      "description": "A record of a monthly payment of 1000rs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "month": { "type": "integer" },
        "year": { "type": "integer" },
        "amount": { "type": "integer" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "month", "year", "amount", "status"]
    },
    "Loan": {
      "title": "Loan Application",
      "description": "A record of a loan application and its status.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "integer" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "declined", "paid"] },
        "approvedAmount": { "type": "integer" },
        "interestRate": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "installments": { "type": "integer" }
      },
      "required": ["userId", "amount", "status", "createdAt"]
    },
    "LoanPayment": {
      "title": "Loan Payment",
      "description": "A record of a monthly loan repayment.",
      "type": "object",
      "properties": {
        "loanId": { "type": "string" },
        "userId": { "type": "string" },
        "month": { "type": "integer" },
        "year": { "type": "integer" },
        "amount": { "type": "number" },
        "interest": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["loanId", "userId", "month", "year", "amount", "interest", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/contributions/{contributionId}": {
      "schema": "Contribution",
      "description": "Monthly contributions records."
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "Loan applications and their status."
    },
    "/loanPayments/{paymentId}": {
      "schema": "LoanPayment",
      "description": "Monthly loan repayment records."
    }
  }
}
